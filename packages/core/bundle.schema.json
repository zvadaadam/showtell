{
  "$ref": "#/definitions/BundleSpec",
  "definitions": {
    "BundleSpec": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "meta": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "fps": {
              "type": "integer",
              "minimum": 1,
              "maximum": 120,
              "default": 30
            },
            "aspectRatios": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "16:9",
                  "9:16",
                  "1:1"
                ]
              },
              "minItems": 1,
              "default": [
                "16:9"
              ]
            },
            "theme": {
              "type": "object",
              "properties": {
                "preset": {
                  "type": "string",
                  "enum": [
                    "ink",
                    "aurora",
                    "ember",
                    "orchid",
                    "graphite",
                    "paper",
                    "neutral"
                  ]
                },
                "colors": {
                  "type": "object",
                  "properties": {
                    "fg": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    },
                    "bg": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    },
                    "subtle": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    },
                    "accent": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    },
                    "accent2": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    },
                    "success": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    },
                    "warning": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    },
                    "surface": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    },
                    "border": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    },
                    "captionBg": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    },
                    "captionFg": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    }
                  },
                  "additionalProperties": false,
                  "default": {}
                },
                "typography": {
                  "type": "object",
                  "properties": {
                    "display": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 80,
                      "pattern": "^[A-Za-z0-9_. -]+$"
                    },
                    "body": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 80,
                      "pattern": "^[A-Za-z0-9_. -]+$"
                    },
                    "mono": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 80,
                      "pattern": "^[A-Za-z0-9_. -]+$"
                    }
                  },
                  "additionalProperties": false,
                  "default": {}
                },
                "chart": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^#[0-9a-fA-F]{6}$"
                  },
                  "minItems": 2,
                  "maxItems": 10
                }
              },
              "additionalProperties": false
            },
            "presenter": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "image": {
                  "type": "string",
                  "minLength": 1
                },
                "model": {
                  "type": "string",
                  "minLength": 1
                },
                "logo": {
                  "type": "string",
                  "minLength": 1
                },
                "position": {
                  "type": "string",
                  "enum": [
                    "auto",
                    "top-left",
                    "top-center",
                    "top-right",
                    "bottom-left",
                    "bottom-right"
                  ],
                  "default": "auto"
                },
                "size": {
                  "type": "string",
                  "enum": [
                    "sm",
                    "md",
                    "lg"
                  ],
                  "default": "md"
                }
              },
              "required": [
                "image"
              ],
              "additionalProperties": false
            },
            "repo": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "default": ".."
                },
                "baseRef": {
                  "type": "string"
                },
                "headRef": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "default": {
                "path": ".."
              }
            }
          },
          "required": [
            "title"
          ],
          "additionalProperties": false
        },
        "assets": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "audio"
                  },
                  "src": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "type",
                  "src"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "data"
                  },
                  "src": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "type",
                  "src"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "image"
                  },
                  "src": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "type",
                  "src"
                ],
                "additionalProperties": false
              }
            ]
          },
          "propertyNames": {
            "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
          },
          "default": {}
        },
        "audio": {
          "type": "object",
          "properties": {
            "tts": {
              "type": "object",
              "properties": {
                "provider": {
                  "type": "string",
                  "enum": [
                    "say",
                    "replicate",
                    "openai",
                    "elevenlabs"
                  ],
                  "description": "TTS provider. Local 'say' uses macOS say or Linux espeak-ng; others are BYO-API."
                },
                "model": {
                  "type": "string"
                },
                "voice": {
                  "type": "string"
                }
              },
              "required": [
                "provider"
              ],
              "additionalProperties": false,
              "default": {
                "provider": "say"
              }
            },
            "captions": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "off",
                    "sidecar",
                    "burn-in",
                    "sidecar-and-burn-in"
                  ],
                  "default": "off"
                },
                "source": {
                  "type": "string",
                  "const": "narration",
                  "default": "narration"
                }
              },
              "additionalProperties": false,
              "default": {
                "mode": "off",
                "source": "narration"
              }
            },
            "music": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
                  },
                  "asset": {
                    "type": "string",
                    "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
                  },
                  "range": {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 1
                      },
                      {
                        "type": "object",
                        "properties": {
                          "from": {
                            "type": "string",
                            "minLength": 1
                          },
                          "to": {
                            "type": "string",
                            "minLength": 1
                          }
                        },
                        "required": [
                          "from",
                          "to"
                        ],
                        "additionalProperties": false
                      }
                    ]
                  },
                  "loop": {
                    "type": "boolean",
                    "default": false
                  },
                  "gainDb": {
                    "type": "number",
                    "maximum": 0,
                    "default": -28
                  },
                  "duckUnderNarration": {
                    "type": "boolean",
                    "default": false
                  },
                  "fadeInMs": {
                    "type": "number",
                    "minimum": 0,
                    "default": 0
                  },
                  "fadeOutMs": {
                    "type": "number",
                    "minimum": 0,
                    "default": 0
                  }
                },
                "required": [
                  "id",
                  "asset",
                  "range"
                ],
                "additionalProperties": false
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "tts": {
              "provider": "say"
            },
            "captions": {
              "mode": "off",
              "source": "narration"
            },
            "music": []
          }
        },
        "version": {
          "type": "number",
          "const": 3
        },
        "scenes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
              },
              "duration": {
                "anyOf": [
                  {
                    "type": "string",
                    "const": "auto"
                  },
                  {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                ],
                "description": "Seconds, or \"auto\" to derive the scene timing from measured narration audio.",
                "default": "auto"
              },
              "narration": {
                "type": "object",
                "properties": {
                  "lines": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
                        },
                        "text": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "id",
                        "text"
                      ],
                      "additionalProperties": false
                    },
                    "minItems": 1
                  }
                },
                "required": [
                  "lines"
                ],
                "additionalProperties": false
              },
              "refs": {
                "type": "object",
                "additionalProperties": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "code"
                        },
                        "file": {
                          "type": "string",
                          "minLength": 1
                        },
                        "lineStart": {
                          "type": "integer",
                          "exclusiveMinimum": 0
                        },
                        "lineEnd": {
                          "type": "integer",
                          "exclusiveMinimum": 0
                        },
                        "ref": {
                          "type": "string"
                        },
                        "focus": {
                          "type": "array",
                          "items": {
                            "type": "integer",
                            "exclusiveMinimum": 0
                          }
                        },
                        "language": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "kind",
                        "file"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "diff"
                        },
                        "file": {
                          "type": "string",
                          "minLength": 1
                        },
                        "ref": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "kind",
                        "file",
                        "ref"
                      ],
                      "additionalProperties": false
                    }
                  ]
                },
                "propertyNames": {
                  "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
                },
                "default": {}
              },
              "beats": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
                    },
                    "lines": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
                      },
                      "minItems": 1
                    }
                  },
                  "required": [
                    "id",
                    "lines"
                  ],
                  "additionalProperties": false
                },
                "default": []
              },
              "anchors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
                    },
                    "at": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "id",
                    "at"
                  ],
                  "additionalProperties": false
                },
                "default": []
              },
              "ranges": {
                "type": "object",
                "additionalProperties": {
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 1
                    },
                    {
                      "type": "object",
                      "properties": {
                        "from": {
                          "type": "string",
                          "minLength": 1
                        },
                        "to": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "from",
                        "to"
                      ],
                      "additionalProperties": false
                    }
                  ]
                },
                "propertyNames": {
                  "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
                },
                "default": {}
              },
              "visual": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "kind": {
                        "type": "string",
                        "const": "web"
                      },
                      "src": {
                        "type": "string",
                        "minLength": 1
                      },
                      "name": {
                        "not": {}
                      },
                      "ref": {
                        "not": {}
                      },
                      "props": {
                        "type": "object",
                        "additionalProperties": {},
                        "default": {}
                      },
                      "inputs": {
                        "type": "object",
                        "additionalProperties": {
                          "anyOf": [
                            {
                              "type": "string",
                              "minLength": 1
                            },
                            {
                              "type": "object",
                              "properties": {
                                "from": {
                                  "type": "string",
                                  "minLength": 1
                                },
                                "to": {
                                  "type": "string",
                                  "minLength": 1
                                }
                              },
                              "required": [
                                "from",
                                "to"
                              ],
                              "additionalProperties": false
                            }
                          ]
                        },
                        "propertyNames": {
                          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
                        },
                        "default": {}
                      }
                    },
                    "required": [
                      "kind",
                      "src"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "kind": {
                        "type": "string",
                        "const": "screencap"
                      },
                      "sessionRef": {
                        "type": "string",
                        "pattern": "^[A-Za-z0-9_-]{1,64}$"
                      },
                      "clip": {
                        "type": "object",
                        "properties": {
                          "start": {
                            "type": "number",
                            "minimum": 0
                          },
                          "end": {
                            "type": "number",
                            "exclusiveMinimum": 0
                          }
                        },
                        "required": [
                          "start",
                          "end"
                        ],
                        "additionalProperties": false
                      },
                      "playback": {
                        "type": "object",
                        "properties": {
                          "mode": {
                            "type": "string",
                            "enum": [
                              "realtime",
                              "action-only",
                              "smart"
                            ],
                            "default": "smart",
                            "description": "\"realtime\" plays linearly; \"action-only\" trims from event sidecars; \"smart\" merges visual activity with event hints."
                          },
                          "preActionPaddingMs": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 10000,
                            "description": "Milliseconds of context to keep before each click/type/scroll/navigate event."
                          },
                          "postActionPaddingMs": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 10000,
                            "description": "Milliseconds of context to keep after each click/type/scroll/navigate event."
                          },
                          "targetGapOutputMs": {
                            "type": "integer",
                            "exclusiveMinimum": 0,
                            "maximum": 10000,
                            "description": "Preferred visible length for long gaps between action windows after compression."
                          },
                          "maxGapOutputMs": {
                            "type": "integer",
                            "exclusiveMinimum": 0,
                            "maximum": 10000,
                            "description": "Maximum visible length for any compressed gap between action windows."
                          },
                          "maxPlaybackRate": {
                            "type": "number",
                            "minimum": 1,
                            "maximum": 64,
                            "description": "Maximum fast-forward rate used for compressed gaps before final narration fitting."
                          },
                          "minGapToSpeedUpMs": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 10000,
                            "description": "Gaps shorter than this stay at normal speed before final narration fitting."
                          },
                          "camera": {
                            "type": "string",
                            "enum": [
                              "auto",
                              "follow",
                              "none"
                            ],
                            "default": "auto",
                            "description": "\"auto\" follows desktop/landscape actions but keeps portrait/mobile captures full-frame."
                          },
                          "actionEffects": {
                            "type": "string",
                            "enum": [
                              "auto",
                              "tap-glow",
                              "none"
                            ],
                            "default": "auto",
                            "description": "\"auto\" adds touch/type feedback when the camera is not following the action."
                          },
                          "visualSampleFps": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 12,
                            "description": "Frame samples per second for \"smart\" visual activity detection. Default: 4."
                          },
                          "visualMinScore": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 50,
                            "description": "Minimum average grayscale frame-diff score for \"smart\" visual activity. Default: 0.7."
                          }
                        },
                        "additionalProperties": false,
                        "description": "How to play back a screencap recording."
                      }
                    },
                    "required": [
                      "kind",
                      "sessionRef"
                    ],
                    "additionalProperties": false
                  }
                ]
              }
            },
            "required": [
              "id",
              "narration",
              "visual"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        }
      },
      "required": [
        "meta",
        "version",
        "scenes"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
