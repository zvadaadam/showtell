{
  "$ref": "#/definitions/VideoSpec",
  "definitions": {
    "VideoSpec": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "meta": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "fps": {
              "type": "integer",
              "minimum": 1,
              "maximum": 120,
              "default": 30
            },
            "aspectRatios": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "16:9",
                  "9:16",
                  "1:1"
                ]
              },
              "minItems": 1,
              "default": [
                "16:9"
              ]
            },
            "tts": {
              "type": "object",
              "properties": {
                "provider": {
                  "type": "string",
                  "enum": [
                    "say",
                    "replicate",
                    "openai",
                    "elevenlabs"
                  ],
                  "description": "TTS provider. Local 'say' uses macOS say or Linux espeak-ng; others are BYO-API."
                },
                "model": {
                  "type": "string"
                },
                "voice": {
                  "type": "string"
                }
              },
              "required": [
                "provider"
              ],
              "additionalProperties": false
            },
            "watermark": {
              "type": [
                "boolean",
                "string"
              ],
              "default": true,
              "description": "Watermark text; true = \"showtell\". Free tier shows it."
            },
            "repo": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "default": "."
                },
                "baseRef": {
                  "type": "string"
                },
                "headRef": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "default": {
                "path": "."
              }
            }
          },
          "required": [
            "title"
          ],
          "additionalProperties": false
        },
        "scenes": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "title"
                  },
                  "content": {
                    "type": "object",
                    "properties": {
                      "heading": {
                        "type": "string",
                        "minLength": 1
                      },
                      "subtitle": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "heading"
                    ],
                    "additionalProperties": false
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Stable scene id (defaults to the scene index if omitted)."
                  },
                  "narration": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Spoken narration for this scene. Always required."
                  },
                  "duration": {
                    "anyOf": [
                      {
                        "type": "string",
                        "const": "auto"
                      },
                      {
                        "type": "number",
                        "exclusiveMinimum": 0
                      }
                    ],
                    "description": "Seconds, or \"auto\" to derive from the narration audio length.",
                    "default": "auto"
                  }
                },
                "required": [
                  "kind",
                  "content",
                  "narration"
                ],
                "additionalProperties": false,
                "description": "A title / section card."
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "code"
                  },
                  "content": {
                    "type": "object",
                    "properties": {
                      "file": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Repo-relative path. Read live; never paste source."
                      },
                      "lineStart": {
                        "type": "integer",
                        "exclusiveMinimum": 0
                      },
                      "lineEnd": {
                        "type": "integer",
                        "exclusiveMinimum": 0
                      },
                      "ref": {
                        "type": "string",
                        "description": "Optional git ref to read the file at (default: working tree)."
                      },
                      "focus": {
                        "type": "array",
                        "items": {
                          "type": "integer",
                          "exclusiveMinimum": 0
                        },
                        "description": "Line numbers to emphasize."
                      },
                      "language": {
                        "type": "string",
                        "description": "Override syntax language (else inferred from extension)."
                      }
                    },
                    "required": [
                      "file"
                    ],
                    "additionalProperties": false
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Stable scene id (defaults to the scene index if omitted)."
                  },
                  "narration": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Spoken narration for this scene. Always required."
                  },
                  "duration": {
                    "anyOf": [
                      {
                        "type": "string",
                        "const": "auto"
                      },
                      {
                        "type": "number",
                        "exclusiveMinimum": 0
                      }
                    ],
                    "description": "Seconds, or \"auto\" to derive from the narration audio length.",
                    "default": "auto"
                  }
                },
                "required": [
                  "kind",
                  "content",
                  "narration"
                ],
                "additionalProperties": false,
                "description": "A syntax-highlighted code excerpt read from the repo at file:line."
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "diff"
                  },
                  "content": {
                    "type": "object",
                    "properties": {
                      "file": {
                        "type": "string",
                        "minLength": 1
                      },
                      "ref": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Git range, e.g. \"main..HEAD\"."
                      },
                      "animation": {
                        "type": "string",
                        "enum": [
                          "magic-move",
                          "fade"
                        ],
                        "default": "magic-move"
                      }
                    },
                    "required": [
                      "file",
                      "ref"
                    ],
                    "additionalProperties": false
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Stable scene id (defaults to the scene index if omitted)."
                  },
                  "narration": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Spoken narration for this scene. Always required."
                  },
                  "duration": {
                    "anyOf": [
                      {
                        "type": "string",
                        "const": "auto"
                      },
                      {
                        "type": "number",
                        "exclusiveMinimum": 0
                      }
                    ],
                    "description": "Seconds, or \"auto\" to derive from the narration audio length.",
                    "default": "auto"
                  }
                },
                "required": [
                  "kind",
                  "content",
                  "narration"
                ],
                "additionalProperties": false,
                "description": "Animated before/after diff of a file, read from git."
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "talking-points"
                  },
                  "content": {
                    "type": "object",
                    "properties": {
                      "heading": {
                        "type": "string"
                      },
                      "points": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "minLength": 1
                        },
                        "minItems": 1
                      }
                    },
                    "required": [
                      "points"
                    ],
                    "additionalProperties": false
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Stable scene id (defaults to the scene index if omitted)."
                  },
                  "narration": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Spoken narration for this scene. Always required."
                  },
                  "duration": {
                    "anyOf": [
                      {
                        "type": "string",
                        "const": "auto"
                      },
                      {
                        "type": "number",
                        "exclusiveMinimum": 0
                      }
                    ],
                    "description": "Seconds, or \"auto\" to derive from the narration audio length.",
                    "default": "auto"
                  }
                },
                "required": [
                  "kind",
                  "content",
                  "narration"
                ],
                "additionalProperties": false,
                "description": "A bulleted list of points (e.g. what reviewers should check)."
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "chart"
                  },
                  "content": {
                    "type": "object",
                    "properties": {
                      "chartType": {
                        "type": "string",
                        "enum": [
                          "bar",
                          "line",
                          "pie"
                        ]
                      },
                      "title": {
                        "type": "string"
                      },
                      "x": {
                        "type": "string",
                        "description": "Optional label/category field used by the built-in chart renderer."
                      },
                      "y": {
                        "type": "string",
                        "description": "Optional numeric value field used by the built-in chart renderer."
                      },
                      "data": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "additionalProperties": {
                            "type": [
                              "string",
                              "number"
                            ]
                          }
                        },
                        "minItems": 1
                      }
                    },
                    "required": [
                      "chartType",
                      "data"
                    ],
                    "additionalProperties": false
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Stable scene id (defaults to the scene index if omitted)."
                  },
                  "narration": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Spoken narration for this scene. Always required."
                  },
                  "duration": {
                    "anyOf": [
                      {
                        "type": "string",
                        "const": "auto"
                      },
                      {
                        "type": "number",
                        "exclusiveMinimum": 0
                      }
                    ],
                    "description": "Seconds, or \"auto\" to derive from the narration audio length.",
                    "default": "auto"
                  }
                },
                "required": [
                  "kind",
                  "content",
                  "narration"
                ],
                "additionalProperties": false,
                "description": "A data-driven chart."
              },
              {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "const": "screencap"
                  },
                  "content": {
                    "type": "object",
                    "properties": {
                      "source": {
                        "type": "string",
                        "enum": [
                          "app",
                          "browser",
                          "desktop"
                        ],
                        "description": "What to capture (macOS/avfoundation)."
                      },
                      "sessionRef": {
                        "type": "string",
                        "pattern": "^[A-Za-z0-9_-]{1,64}$",
                        "description": "Recorded capture session id (a filename under .showtell/captures, not a path)."
                      },
                      "clip": {
                        "type": "object",
                        "properties": {
                          "start": {
                            "type": "number",
                            "minimum": 0
                          },
                          "end": {
                            "type": "number",
                            "exclusiveMinimum": 0
                          }
                        },
                        "required": [
                          "start",
                          "end"
                        ],
                        "additionalProperties": false
                      },
                      "playback": {
                        "type": "object",
                        "properties": {
                          "mode": {
                            "type": "string",
                            "enum": [
                              "realtime",
                              "action-only",
                              "smart"
                            ],
                            "default": "smart",
                            "description": "\"realtime\" plays linearly; \"action-only\" trims from event sidecars; \"smart\" merges visual activity with event hints."
                          },
                          "preActionPaddingMs": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 10000,
                            "description": "Milliseconds of context to keep before each click/type/scroll/navigate event."
                          },
                          "postActionPaddingMs": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 10000,
                            "description": "Milliseconds of context to keep after each click/type/scroll/navigate event."
                          },
                          "targetGapOutputMs": {
                            "type": "integer",
                            "exclusiveMinimum": 0,
                            "maximum": 10000,
                            "description": "Preferred visible length for long gaps between action windows after compression."
                          },
                          "maxGapOutputMs": {
                            "type": "integer",
                            "exclusiveMinimum": 0,
                            "maximum": 10000,
                            "description": "Maximum visible length for any compressed gap between action windows."
                          },
                          "maxPlaybackRate": {
                            "type": "number",
                            "minimum": 1,
                            "maximum": 64,
                            "description": "Maximum fast-forward rate used for compressed gaps before final narration fitting."
                          },
                          "minGapToSpeedUpMs": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 10000,
                            "description": "Gaps shorter than this stay at normal speed before final narration fitting."
                          },
                          "camera": {
                            "type": "string",
                            "enum": [
                              "auto",
                              "follow",
                              "none"
                            ],
                            "default": "auto",
                            "description": "\"auto\" follows desktop/landscape actions but keeps portrait/mobile captures full-frame."
                          },
                          "actionEffects": {
                            "type": "string",
                            "enum": [
                              "auto",
                              "tap-glow",
                              "none"
                            ],
                            "default": "auto",
                            "description": "\"auto\" adds touch/type feedback when the camera is not following the action."
                          },
                          "visualSampleFps": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 12,
                            "description": "Frame samples per second for \"smart\" visual activity detection. Default: 4."
                          },
                          "visualMinScore": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 50,
                            "description": "Minimum average grayscale frame-diff score for \"smart\" visual activity. Default: 0.7."
                          }
                        },
                        "additionalProperties": false,
                        "description": "How to play back a screencap recording."
                      }
                    },
                    "required": [
                      "source",
                      "sessionRef"
                    ],
                    "additionalProperties": false
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Stable scene id (defaults to the scene index if omitted)."
                  },
                  "narration": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Spoken narration for this scene. Always required."
                  },
                  "duration": {
                    "anyOf": [
                      {
                        "type": "string",
                        "const": "auto"
                      },
                      {
                        "type": "number",
                        "exclusiveMinimum": 0
                      }
                    ],
                    "description": "Seconds, or \"auto\" to derive from the narration audio length.",
                    "default": "auto"
                  }
                },
                "required": [
                  "kind",
                  "content",
                  "narration"
                ],
                "additionalProperties": false,
                "description": "A screen-capture segment (Mode A) composited into the timeline."
              }
            ]
          },
          "minItems": 1,
          "description": "Ordered scenes; the video plays them in sequence."
        }
      },
      "required": [
        "meta",
        "scenes"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
