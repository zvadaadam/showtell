{
  "name": "showtell",
  "version": "0.1.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "description": "Open-source motion engine for videos made by agents, for humans.",
  "homepage": "https://github.com/zvadaadam/showtell#readme",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "validate": "bun packages/cli/src/index.ts validate",
    "showtell": "bun packages/cli/src/index.ts",
    "build:cli": "bun scripts/compile-cli.ts --outfile dist/showtell",
    "build:npm": "bun scripts/build-npm-package.ts",
    "publish:npm": "bun scripts/publish-npm.ts",
    "build:player": "cd packages/player && bun --bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "lint": "oxlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:schema": "bun scripts/gen-schema.ts",
    "check:generated": "bun scripts/gen-schema.ts --check",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run check:generated && bun test",
    "prepare": "lefthook install",
    "build:release": "bun scripts/build-release.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "lefthook": "2.1.9",
    "oxlint": "0.15.15",
    "playwright": "1.61.1",
    "prettier": "3.8.4",
    "typescript": "5.9.3"
  }
}
